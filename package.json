{
  "name": "rdp-connector",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --fix",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "freerdp:build": "./freerdp/build.sh",
    "test": "run-p test:frontend test:rust",
    "test:frontend": "vitest --run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "docs:dev": "npm run docs:prepare && vitepress dev docs",
    "docs:build": "npm run docs:prepare && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:prepare": "cp README.md docs/index.md && cp CHANGELOG.md docs/changelog.md && mkdir -p docs/assets && cp -r assets/* docs/assets/ && mkdir -p docs/public && cp -r docs/assets docs/public/"
  },
  "dependencies": {
    "@fontsource/roboto": "5.2.10",
    "@mdi/font": "7.4.47",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-store": "^2.4.3",
    "pinia": "^3.0.4",
    "vue-router": "^5.1.0",
    "vuetify": "^4.0.8"
    "vue": "^3.5.38",
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "@tsconfig/node24": "^24.0.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "@types/node": "^25.9.2",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.0",
    "eslint-config-vuetify": "^4.6.2",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.1",
    "sass-embedded": "^1.99.0",
    "typescript": "~6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-fonts": "^2.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16",
    "vite-plugin-vue-layouts-next": "^2.1.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vitepress": "^2.0.0-alpha.17",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.3.4"
  }
}
